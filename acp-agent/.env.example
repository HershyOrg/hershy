# ACP wallet + identity (required)
WHITELISTED_WALLET_PRIVATE_KEY=0x...
ACP_SESSION_ENTITY_KEY_ID=12345
SELLER_AGENT_WALLET_ADDRESS=0x...

# ACP network: base-sepolia or base
ACP_NETWORK=base-sepolia

# Hershy Host API
HERSHY_HOST_URL=http://localhost:9000
HERSHY_HOST_API_TOKEN=

# Access grant config (required)
# Option A) direct defaults (register up to 2 servers)
ACP_PERSISTENT_WS_URL=wss://stream.example.com/ws/live
ACP_SESSION_WS_URL=wss://stream.example.com/ws/session
ACP_ACCESS_SESSION_DEFAULT_TTL_SEC=900
ACP_ACCESS_SESSION_MAX_TTL_SEC=3600

# Option B) full JSON registry (overrides ACP_PERSISTENT_WS_URL/ACP_SESSION_WS_URL when set)
# ACP_WS_SERVER_REGISTRY_JSON={"persistent-default":{"mode":"persistent","ws_url":"wss://stream.example.com/ws/live"},"session-default":{"mode":"session","ws_url":"wss://stream.example.com/ws/session","default_ttl_sec":900,"max_ttl_sec":3600}}

# Optional token signing key for access token in encrypted payload
ACP_ACCESS_TOKEN_SIGNING_KEY=
ACP_ACCESS_TOKEN_ISSUER=hershy-acp-seller

# Access gateway (same process as ACP resource server)
# If enabled, ACP deliverable can point to this gateway URL instead of upstream ws_url
ACP_ACCESS_GATEWAY_ENABLE=false
ACP_ACCESS_GATEWAY_WS_URL=wss://seller.example.com/access/ws
ACP_ACCESS_GATEWAY_HTTP_URL=https://seller.example.com/access/http

# Provisioning defaults
ACP_DEFAULT_TEMPLATE=simple-counter
ACP_AUTO_START_DEFAULT=true
ACP_WAIT_READY_DEFAULT=true
ACP_READY_TIMEOUT_SEC_DEFAULT=300
ACP_HOST_POLL_INTERVAL_MS=2500
ACP_ALLOW_CUSTOM_SOURCE=false

# Optional local resource server for ACP resource offerings
# 0 disables it
ACP_RESOURCE_PORT=9095

# Optional local testing mode (no websocket listener)
ACP_SKIP_SOCKET_CONNECTION=false

# Optional alternate aliases kept for ACP.md compatibility
# SELLER_ENTITY_ID=12345
# ACP_WALLET_PRIVATE_KEY=0x...
# ACP_AGENT_WALLET_ADDRESS=0x...
